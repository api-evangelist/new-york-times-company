{
  "opencollection": "1.0.0",
  "info": {
    "name": "Top Stories",
    "version": "2.0.0"
  },
  "items": [
    {
      "info": {
        "name": "Stories",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Top Stories",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "{{baseUrl}}/:section.json",
            "params": [
              {
                "name": "section",
                "value": "",
                "type": "path",
                "description": "The section the story appears in."
              }
            ]
          },
          "docs": "The Top Stories API returns an array of articles currently on the specified section.\n"
        }
      ]
    }
  ],
  "bundled": true
}